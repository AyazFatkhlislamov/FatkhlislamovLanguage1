<Page x:Class="SavelyevLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SavelyevLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ListView Name="ClientListView" Grid.Row="1" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Width="130" Stretch="Uniform" Grid.Column="0" Grid.RowSpan="7" VerticalAlignment="Center">
                                <Image.Source>
                                    <Binding Path="ClientPhotoPath">
                                        <Binding.TargetNullValue>
                                            <ImageSource>res/picture.png</ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0">
                                <TextBlock Text="{Binding ID, StringFormat=ID: {0}}" FontSize="17" FontWeight="Bold"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding FullName}" FontSize="17" FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Gender.Name, StringFormat=Пол: {0}}" Grid.Column="1" Grid.Row="1" FontSize="15"/>

                            <TextBlock Text="{Binding Birthday, StringFormat=Дата рождения: {0:dd.MM.yyyy}}" Grid.Column="1" Grid.Row="2" FontSize="15"/>

                            <TextBlock Text="{Binding Phone, StringFormat=Телефон: {0}}" Grid.Column="1" Grid.Row="3" FontSize="15"/>

                            <TextBlock Text="{Binding Email, StringFormat=Электронная почта: {0}}" Grid.Column="1" Grid.Row="4" FontSize="15"/>

                            <TextBlock Text="{Binding RegistrationDate, StringFormat=Дата добавления: {0:dd.MM.yyyy}}" Grid.Column="1" Grid.Row="5" FontSize="15"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
