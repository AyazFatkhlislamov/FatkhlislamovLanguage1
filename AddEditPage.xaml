<Page x:Class="FatkhlislamovLanguage.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FatkhlislamovLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="850"
      Title="Добавление / Редактирование" FontFamily="Comic Sans MS">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <!-- Ширина под надписи -->
            <ColumnDefinition Width="150"/>
            <!-- Ширина под текстовые поля: "*" заставляет их растянуться на всё свободное пространство вправо -->
            <ColumnDefinition Width="*"/>
            <!-- Ширина под картинку -->
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Name="TextBlockId" Text="ID:" Grid.Row="0" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Name="TBoxId" Text="{Binding ID}" Grid.Row="0" Grid.Column="1" FontSize="16" Margin="5" IsReadOnly="True" Background="#EEEEEE"/>

        <!-- Добавлено TextWrapping="Wrap" чтобы длинный текст было видно -->
        <TextBlock Text="Фамилия:" Grid.Row="1" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Text="{Binding FirstName}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="16" Margin="5"/>

        <TextBlock Text="Имя:" Grid.Row="2" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Text="{Binding LastName}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="16" Margin="5"/>

        <TextBlock Text="Отчество:" Grid.Row="3" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Text="{Binding Patronymic}" TextWrapping="Wrap" Grid.Row="3" Grid.Column="1" FontSize="16" Margin="5"/>

        <TextBlock Text="Email:" Grid.Row="4" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Text="{Binding Email}" TextWrapping="Wrap" Grid.Row="4" Grid.Column="1" FontSize="16" Margin="5"/>

        <TextBlock Text="Телефон:" Grid.Row="5" Grid.Column="0" FontSize="16" Margin="5"/>
        <TextBox Text="{Binding Phone}" TextWrapping="Wrap" Grid.Row="5" Grid.Column="1" FontSize="16" Margin="5"/>

        <TextBlock Text="Дата рождения:" Grid.Row="6" Grid.Column="0" FontSize="16" Margin="5"/>
        <DatePicker SelectedDate="{Binding Birthday}" Grid.Row="6" Grid.Column="1" FontSize="16" Margin="5" HorizontalAlignment="Left" Width="200"/>

        <TextBlock Text="Пол:" Grid.Row="7" Grid.Column="0" FontSize="16" Margin="5"/>
        <StackPanel Orientation="Horizontal" Grid.Row="7" Grid.Column="1" Margin="5" VerticalAlignment="Center">
            <RadioButton Name="RbMale" Content="Мужской" FontSize="16" Margin="0,0,20,0"/>
            <RadioButton Name="RbFemale" Content="Женский" FontSize="16"/>
        </StackPanel>

        <Button Content="Сохранить" Grid.Row="8" Grid.Column="1" Margin="5,20,5,5" Width="150" Height="35" HorizontalAlignment="Left" Background="#04A0FF" Foreground="Black" BorderBrush="Black" FontSize="16" Click="BtnSave_Click"/>

        <!-- Блок с фото -->
        <StackPanel Grid.Column="2" Grid.RowSpan="9" Margin="20,5,5,5" HorizontalAlignment="Center">
            <Image Name="ClientImage" Width="200" Height="200" Stretch="UniformToFill" Margin="0,0,0,10">
                <Image.Source>
                    <Binding Path="ClientPhotoPath">
                        <Binding.TargetNullValue>
                            <ImageSource>res/picture.png</ImageSource>
                        </Binding.TargetNullValue>
                    </Binding>
                </Image.Source>
            </Image>
            <Button Content="Выбрать фото" Height="30" FontSize="15" Background="#04A0FF" Foreground="Black" BorderBrush="Black" Click="BtnChangePhoto_Click"/>
        </StackPanel>
    </Grid>
</Page>
